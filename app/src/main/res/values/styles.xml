<resources>

    <!-- Base Button -->
    <style name="CalcButtonBase">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <!-- Dark Numbers -->
    <style name="CalcButtonDark" parent="CalcButtonBase">
        <item name="android:backgroundTint">#27314F</item>
    </style>

    <!-- Gray Top Buttons -->
    <style name="CalcButtonGray" parent="CalcButtonBase">
        <item name="android:backgroundTint">#3B445B</item>
    </style>

    <!-- Orange Operators -->
    <style name="CalcButtonOrange" parent="CalcButtonBase">
        <item name="android:backgroundTint">#FF9500</item>
    </style>

    <!-- Green Equal -->
    <style name="CalcButtonGreen" parent="CalcButtonBase">
        <item name="android:backgroundTint">#28D063</item>
    </style>

</resources>